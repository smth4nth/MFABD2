#!/bin/bash

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# ==================== 🛡️ 1. 精准保护区域 (逻辑修正版) ====================
# 我们只拦截“明确是用户手动输入”的情况。
# source 为 'message' 代表使用了 -m 参数
# source 为 'commit'  代表使用了 --amend (修补提交)
# 注意：这里千万不能拦截 'merge'，否则命令行合并会直接跳过 Hook！

if [ "$COMMIT_SOURCE" = "message" ] || [ "$COMMIT_SOURCE" = "commit" ]; then
    # 用户自己写了信息，或者正在修补提交，直接放行，不许覆盖！
    exit 0
fi

# ==================== ✨ 2. 合并提交拦截区域 ✨ ====================
# 逻辑：
# A. 来源必须是 merge (针对命令行合并)
#    或者
# B. 文件内容包含 "Merge branch" (针对 VS Code 等工具自动填充的情况)

if [ "$COMMIT_SOURCE" = "merge" ] || grep -q "^Merge branch" "$COMMIT_MSG_FILE"; then
    
    # [双重保险]：再次确认这不是用户手写的非标准 Merge 信息
    # 如果用户手写了 "Merge branch..." 但 source 是 message，上面的保护区已经拦截了。
    # 能跑到这里，说明大概率是自动生成的。

    # 读取原始信息
    ORIGINAL_MSG=$(cat "$COMMIT_MSG_FILE")
    # 尝试提取分支名
    BRANCH_NAME=$(echo "$ORIGINAL_MSG" | sed -n "s/^Merge branch '\([^']*\)'.*/\1/p")
    if [ -z "$BRANCH_NAME" ]; then
        BRANCH_NAME=$(echo "$ORIGINAL_MSG" | sed -n "s/^Merge branch \([^ ]*\).*/\1/p")
    fi
    # 清理 origin/ 前缀
    BRANCH_NAME=${BRANCH_NAME#origin/}

    # 写入新模板
    cat > "$COMMIT_MSG_FILE" << EOF
Merge:'$BRANCH_NAME'| 请在此输入功能描述(必填)

# 🚧🚧🚧 请修改上方 '|' 后的描述！保持一行！🚧🚧🚧
# 格式: Merge:'分支名'| 描述
# 示例: Merge:'feat/gacha-v2'| 抽卡系统V2重构
#
# 【🚨可自定义信息录入完毕🚨】提交信息请在此行以上☝️☝️☝️输入完毕。

# 【🏗️发版控制】如果要发布公测版\内测版\双发，请删除下面一行开头的#号。单选！
#[deploy-beta]
#[deploy-alpha]
#[deploy-sync]
# =========== 原始信息 ===========
# $ORIGINAL_MSG
EOF
    # 处理完毕，直接退出
    exit 0
fi

# ====================现有输入保护区域===================
# 如果提交信息已经有来源 (例如 VSCode 输入框、git commit -m、git commit --amend)
# 则直接退出，绝对不要覆盖用户已经写好的内容！
if [ "$COMMIT_SOURCE" = "message" ] || [ "$COMMIT_SOURCE" = "commit" ]; then
    exit 0
fi

# ==================== 📝 空白提交帮扶区域 (仅无参 git commit 触发) ====================
# 中文帮扶模板
cat > "$COMMIT_MSG_FILE" << 'EOF'
# =========== 请按照以下语法编写提交信息 ===========
# "💠已打开提交信息编辑器"
#
# 可设置VSCode为默认编辑器，大大提升体验：
# git config --global core.editor "code --wait"
# 更多编辑器参考后文
# 
# 以 '#' 开头的行将被忽略。
# 
# "🚸使用说明："
# "   1. 将【请在此输入提交标题】替换为带前缀的实际标题"
# "   2. 将【请在此输入提交正文（可选）】替换为实际描述" 
# "   3. 如需发布公测版，删除 #[deploy-beta] 前的 # 号"
# "   4. 保存并关闭编辑器，即可完成提交"
#
# "🛑空白的提交信息、不储存直接关闭文本框将中止提交。
#
# 请在下面输入提交标题（简短描述）
# 注意：标题行不要以#号开头
# 🚧🚧🚧     📝第一步：👇在下行撰写提交标题！(subject)    🚧🚧🚧  

#（标题允许设置→破坏性变更标记:主题中使用感叹号"feat!: ***")
# 请保留下方空行（标题和正文之间必须有空行）


#  请在下面输入提交正文（详细描述，可选）
# 🚧🚧🚧     📝第二步：👇请在下方行中输入提交正文（可选）(body)    🚧🚧🚧

# （【可选功能，自行删除注释后替换***内容】
# BREAKING CHANGE:（***破坏性变更警示⚠️，慎用）
# HIGHLIGHT:***（亮点功能标记💡，慎用）
# Co-authored-by:***（协作者名称👥）
# 【🚨可自定义信息录入完毕🚨】提交信息请在此行以上☝️☝️☝️输入完毕。

# 【🏗️发版控制】如果要发布公测版\内测版，请删除下面一行开头的#号
#[deploy-beta]
#[deploy-alpha]
# 注意：请确保这是最后一行，且前后不要有空行


# =========== 以下为Git自动生成的信息，请勿修改 ===========
# 以 '#' 开头的行将被忽略。
#
# 在命令行输出提交前缀规范
# ""
# "🚀 提交前缀规范（请在标题中使用）："
# "==========================================="
# "【Tier 1 - 功能与质量更新】项目有实质改变，进 Changelog 主体"
# "  ✨ feat     - 新功能       (示例: feat: 添加任务调度)"
# "  🐛 fix      - Bug修复      (示例: fix: 解决内存泄漏)"
# "  💪 impr     - 功能增强     (示例: impr: 优化用户体验)"
# "  🚀 perf     - 性能优化     (示例: perf: 加速渲染20%)"
# "  🚜 refactor - 代码重构     (示例: refactor(core): 优化结构)"
# "  ◀️  revert   - 撤销变更     (示例: revert: 回退错误提交)"
# ""
# "【Tier 2 - 工程与生态基建】纯维护，正式版折叠展示"
# "  📚 docs     - 文档         (示例: docs: 更新说明)"
# "  ⚙️  ci       - CI配置       (示例: ci: 调整环境变量)"
# "  🧪 test     - 测试         (示例: test: 增加覆盖)"
# "  🔨 build    - 构建系统     (示例: build: 更新编译配置)"
# "  🎨 style    - 代码格式     (示例: style: 统一缩进)"
# "  🔧 chore    - 杂项维护     (示例: chore: 更新依赖)"
# ""
# "【scope 规则】type 决定归哪层，scope 只标注地方"
# "  fix(ci): 修复CI脚本Bug    → Tier 1（因为 type=fix）"
# "  feat(docs): 新增文档生成   → Tier 1（因为 type=feat）"
# "  ci: 调整环境变量           → Tier 2（因为 type=ci，纯维护）"
# ""
# "📋 变更日志效果："
# "   - ✨ feat → 显示为'新功能'"
# "   - 🐛 fix  → 显示为'Bug修复'"
# "   - 以此类推..."
# ""
# "🎯 特殊标记语法（让提交信息更生动）"
# "═══════════════════════════════════════════════════════════════"
# ""
# "⚠️ 破坏性变更标记（用户需要注意的重要变更）"
# "   ┌─────────────────────────────────────────────────────────┐"
# "   │ 启用方法：                                              │"
# "   │   • 标题中使用感叹号: feat!: 移除旧API                 │"
# "   │   • 正文中添加: BREAKING CHANGE: 接口已变更            │"
# "   │   • 混合使用效果更佳                                   │"
# "   │                                                        │"
# "   │ 显示效果：⚠️ [破坏性变更]                              │"
# "   │ 设计目的：对用户有明显影响的变更                       │"
# "   └─────────────────────────────────────────────────────────┘"
# ""
# "💡 亮点功能标记（值得关注的新特性）"
# "   ┌─────────────────────────────────────────────────────────┐"
# "   │ 启用方法：                                              │"
# "   │   • 正文中添加: HIGHLIGHT: 重要新功能                   │"
# "   │                                                        │"
# "   │ 显示效果：💡 在提交信息前添加灯泡图标                  │"
# "   │ 使用场景：重大更新、核心功能增强                       │"
# "   └─────────────────────────────────────────────────────────┘"
# ""
# "👥 协作者标记（多人协作时使用）"
# "   ┌─────────────────────────────────────────────────────────┐"
# "   │ 启用方法：                                              │"
# "   │   • 正文中添加: Co-authored-by: 协作者姓名              │"
# "   │                                                        │"
# "   │ 显示效果：@提交者 👥协作者姓名                         │"
# "   │ 使用场景：多人共同完成的提交                            │"
# "   └─────────────────────────────────────────────────────────┘"
# ""
# "🎪 完整示例展示"
# "   ┌─────────────────────────────────────────────────────────┐"
# "   │ 破坏性变更示例：                                        │"
# "   │   feat!: 移除用户管理旧API                             │"
# "   │                                                        │"
# "   │   BREAKING CHANGE: 用户接口完全重构，请更新客户端       │"
# "   │                                                        │"
# "   │ 亮点功能示例：                                          │"
# "   │   feat: 新增AI对话功能                                 │"
# "   │                                                        │"
# "   │   HIGHLIGHT: 集成GPT-4，支持多轮对话                   │"
# "   │                                                        │"
# "   │ 协作者示例：                                            │"
# "   │   fix: 修复登录验证漏洞                                │"
# "   │                                                        │"
# "   │   Co-authored-by: 张三                                │"
# "   │   Co-authored-by: 李四                                │"
# "   └─────────────────────────────────────────────────────────┘"
# ""
# "💎 小贴士："
# "   • 破坏性变更标记会让用户特别注意这个更新"
# "   • 亮点功能标记适合展示重要的新特性"
# "   • 协作者标记让团队贡献更加透明"
# ""
#   【破坏性变更标记】：此更新在信息列表中加注‘警告’表情符号
#   设计目的：指对用户有明显影响，不关注有受损害可能的更新
#   启用方法：在主题中使用感叹号,"feat!: ***"、在提交信息正文中添加,git commit -m "feat: ** | body:| BREAKING CHANGE:***"、混合使用
#
# 查看当前的Git编辑器配置
#git config --global core.editor
#
# 查看所有Git配置
#git config --global --list
# VSCode
#git config --global core.editor "code --wait"
#
# VSCode Insiders
#git config --global core.editor "code-insiders --wait"
#
# Sublime Text
#git config --global core.editor "subl -n -w"
#
# Atom
#git config --global core.editor "atom --wait"
#
# Notepad++
#git config --global core.editor "'C:/Program Files/Notepad++/notepad++.exe' -multiInst -notabbar -nosession -noPlugin"
EOF